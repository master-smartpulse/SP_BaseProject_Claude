{
  "permissions": {
    "allow": [
      "Bash(bash scripts/bash/*)",
      "Bash(bash scripts/tests/*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.local)",
      "Read(.env.development)",
      "Read(.env.test)",
      "Read(.env.staging)",
      "Read(.env.production)",
      "Read(.env.*.local)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/scripts/bash/hooks/pre-bash-guard.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          { "type": "command", "command": "bash \"$CLAUDE_PROJECT_DIR\"/scripts/bash/hooks/post-edit-format.sh" }
        ]
      }
    ]
  }
}
